generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  ADMIN
  USER
}

enum PollStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model User {
  uuid      String    @id @default(uuid())
  email     String    @unique
  password  String
  type      UserType  @default(USER)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userRoles UserRole[]
  polls     Poll[]
  votes     Vote[]

  @@index([deletedAt])
}

model Role {
  uuid        String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]
}

model Permission {
  uuid        String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
}

model UserRole {
  userUuid String
  roleUuid String

  user User @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  role Role @relation(fields: [roleUuid], references: [uuid], onDelete: Cascade)

  @@id([userUuid, roleUuid])
  @@index([roleUuid])
}

model RolePermission {
  roleUuid       String
  permissionUuid String

  role       Role       @relation(fields: [roleUuid], references: [uuid], onDelete: Cascade)
  permission Permission @relation(fields: [permissionUuid], references: [uuid], onDelete: Cascade)

  @@id([roleUuid, permissionUuid])
  @@index([permissionUuid])
}

model Audit {
  uuid       String   @id @default(uuid())
  actorUuid  String?
  actorEmail String?
  action     String
  entity     String
  entityUuid String?
  oldData    Json?
  newData    Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorUuid])
  @@index([entity])
  @@index([entityUuid])
  @@index([createdAt])
}

model EventLog {
  uuid      String   @id @default(uuid())
  level     String
  message   String
  context   String?
  stack     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level])
  @@index([createdAt])
}

model Poll {
  uuid        String     @id @default(uuid())
  title       String
  description String?
  status      PollStatus @default(DRAFT)

  startsAt DateTime?
  endsAt   DateTime?

  createdByUuid String
  createdBy     User   @relation(fields: [createdByUuid], references: [uuid])

  options PollOption[]
  votes   Vote[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([createdByUuid])
  @@index([deletedAt])
  @@index([createdAt])
}

model PollOption {
  uuid  String @id @default(uuid())
  label String

  pollUuid String
  poll     Poll   @relation(fields: [pollUuid], references: [uuid], onDelete: Cascade)

  votes Vote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pollUuid])
}

model Vote {
  uuid String @id @default(uuid())

  pollUuid String
  poll     Poll   @relation(fields: [pollUuid], references: [uuid], onDelete: Cascade)

  optionUuid String
  option     PollOption @relation(fields: [optionUuid], references: [uuid], onDelete: Cascade)

  userUuid String
  user     User   @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pollUuid, userUuid])
  @@index([pollUuid])
  @@index([optionUuid])
  @@index([userUuid])
}
